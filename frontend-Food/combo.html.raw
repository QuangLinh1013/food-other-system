<!DOCTYPE html>

<html class="light" lang="vi"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&amp;family=Plus+Jakarta+Sans:wght@700;800&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "surface-container-low": "#f0f1f1",
                        "primary": "#8e4900",
                        "tertiary-dim": "#634d00",
                        "tertiary-fixed": "#fccc33",
                        "secondary-dim": "#2e536c",
                        "on-tertiary-container": "#594500",
                        "primary-fixed": "#fd8603",
                        "on-secondary-container": "#2d526b",
                        "on-surface-variant": "#5a5c5c",
                        "on-error-container": "#520c00",
                        "surface-container-lowest": "#ffffff",
                        "surface": "#f6f6f6",
                        "on-tertiary-fixed": "#423200",
                        "on-primary-fixed-variant": "#4f2600",
                        "error-dim": "#b92902",
                        "on-background": "#2d2f2f",
                        "primary-container": "#fd8603",
                        "inverse-surface": "#0c0f0f",
                        "surface-container-highest": "#dbdddd",
                        "primary-dim": "#7d3f00",
                        "outline": "#757777",
                        "on-tertiary-fixed-variant": "#644e00",
                        "surface-container": "#e7e8e8",
                        "on-error": "#ffefec",
                        "secondary-container": "#bce1ff",
                        "secondary-fixed": "#bce1ff",
                        "secondary": "#3b5f78",
                        "on-secondary-fixed-variant": "#375c75",
                        "error-container": "#f95630",
                        "outline-variant": "#acadad",
                        "inverse-on-surface": "#9c9d9d",
                        "on-primary-fixed": "#0f0400",
                        "tertiary-container": "#fccc33",
                        "on-tertiary": "#fff1d6",
                        "on-secondary-fixed": "#183f57",
                        "surface-variant": "#dbdddd",
                        "surface-tint": "#8e4900",
                        "tertiary-fixed-dim": "#edbe23",
                        "on-primary-container": "#421e00",
                        "background": "#f6f6f6",
                        "tertiary": "#715800",
                        "primary-fixed-dim": "#e97b00",
                        "inverse-primary": "#fd8603",
                        "secondary-fixed-dim": "#aed3f1",
                        "surface-bright": "#f6f6f6",
                        "error": "#b02500",
                        "surface-container-high": "#e1e3e3",
                        "on-surface": "#2d2f2f",
                        "on-primary": "#fff0e7",
                        "surface-dim": "#d2d5d5",
                        "on-secondary": "#e9f4ff"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "fontFamily": {
                        "headline": ["Plus Jakarta Sans"],
                        "body": ["Inter"],
                        "label": ["Inter"]
                    }
                },
            },
        }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .kinetic-gradient {
            background: linear-gradient(135deg, #8e4900 0%, #fd8603 100%);
        }
        .glass-header {
            background-color: rgba(246, 246, 246, 0.8);
            backdrop-filter: blur(20px);
        }
    </style>
</head>
<body class="bg-surface text-on-background font-body selection:bg-primary-container selection:text-on-primary-fixed">
<!-- TopNavBar -->
<header class="fixed top-0 w-full z-50 glass-header">
<nav class="flex justify-between items-center px-6 py-4 max-w-7xl mx-auto h-20">
<div class="text-2xl font-black italic text-orange-600 dark:text-orange-500 font-headline tracking-tighter">
                Linhfood
            </div>
<div class="hidden md:flex items-center gap-8 font-headline font-bold text-lg">
<a class="text-zinc-600 dark:text-zinc-400 hover:text-orange-400 transition-opacity" href="#">Menu</a>
<a class="text-orange-600 dark:text-orange-500 border-b-4 border-orange-500 pb-1" href="#">Combos</a>
<a class="text-zinc-600 dark:text-zinc-400 hover:text-orange-400 transition-opacity" href="#">Offers</a>
<a class="text-zinc-600 dark:text-zinc-400 hover:text-orange-400 transition-opacity" href="#">Orders</a>
</div>
<div class="flex items-center gap-4">
<button class="material-symbols-outlined p-2 text-zinc-600 hover:opacity-80 transition-transform active:scale-90" data-icon="shopping_cart">shopping_cart</button>
<button class="material-symbols-outlined p-2 text-zinc-600 hover:opacity-80 transition-transform active:scale-90" data-icon="account_circle">account_circle</button>
</div>
</nav>
</header>
<main class="pt-20">
<!-- Hero Banner -->
<section class="relative h-[500px] overflow-hidden bg-zinc-900">
<img alt="Siêu Combo" class="absolute inset-0 w-full h-full object-cover opacity-70" data-alt="Vibrant wide shot of a festive food spread with gourmet burgers, artisan pizza, crispy fries, and refreshing iced drinks on a dark textured table" src="https://lh3.googleusercontent.com/aida-public/AB6AXuACmQ-MgSIGzS1rnTsYXJdK9FeoFfDu5dtTJ2CMrhZdVxdZN-lDpZ_DvI3LTCq6K2oKl5WKnoyvuLPH-X_bowAESY1v6yVaLizqxqkw4j5LTtBrlJp3B90gBVGWLiwo5skRBJR9GC96st_Hrs7E5g7Ue23Y7HOJeKQRejVNv4tbBuvrGtO8ItTdaSzISirRUT7oZxx6SUVvkSsE7NKdymGPD095I_4UuycwFGqF-SFQUyit0qWueG0oU8KTJvGORO2efqY0-eXpnoc"/>
<div class="absolute inset-0 bg-gradient-to-r from-zinc-950 via-zinc-950/40 to-transparent"></div>
<div class="relative max-w-7xl mx-auto px-6 h-full flex flex-col justify-center items-start">
<span class="bg-tertiary-container text-on-tertiary-container font-headline font-extrabold px-4 py-1 rounded-full text-sm mb-6 tracking-wider">LIMITED TIME ONLY</span>
<h1 class="text-white font-headline font-extrabold text-5xl md:text-7xl leading-tight mb-8 max-w-2xl">
                    Siêu Combo <br/>
<span class="text-primary-fixed">Tiết Kiệm Tới 50%</span>
</h1>
<button class="kinetic-gradient text-on-primary font-headline font-bold px-10 py-4 rounded-lg text-xl hover:scale-105 transition-transform shadow-2xl">
                    Khám phá ngay
                </button>
</div>
</section>
<!-- Section 1: Combo Bán Chạy -->
<section class="max-w-7xl mx-auto px-6 py-20">
<div class="flex justify-between items-end mb-12">
<div>
<h2 class="font-headline font-extrabold text-4xl mb-2">Combo Bán Chạy</h2>
<p class="text-on-surface-variant text-lg">Những lựa chọn được yêu thích nhất tuần này</p>
</div>
</div>
<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
<!-- Combo Card 1 -->
<div class="group bg-surface-container-lowest rounded-xl overflow-hidden hover:scale-[1.03] transition-all duration-300 hover:shadow-[0_40px_40px_-20px_rgba(45,47,47,0.06)]">
<div class="aspect-square overflow-hidden relative">
<img alt="Combo Gà Rán &amp; Pepsi" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" data-alt="Top down close-up of two pieces of golden crispy fried chicken with a tall glass of sparkling Pepsi and ice on a clean white surface" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDbnd1UsStZe08A4c2Ums7VZAhZ7DtbvA5OLVteV48WnHxDwM_8a26eDKGZ1OWWF3UhuuAlEuY5OB4UalUIN1RujSPxy-zajlzffbC230OOUjydL1pa6G3eCpXTPXbiZo0URjJiUFqgrKbvF7V08zmCnegnXSPjKM4PkeJW-nKvB0gjr8BWvUI4FZWf4wzQjlzod9xN9Jnn_fnNXJK3j-0ezRVA44WYC0Zo5gvfN26c1U99ulgW5kwBHMwj_j4VVKZcOiCAxD8L390"/>
<div class="absolute top-4 right-4 bg-error text-on-error font-headline font-extrabold px-3 py-1 rounded-lg text-xs">HOT SELLER</div>
</div>
<div class="p-8">
<h3 class="font-headline font-bold text-2xl mb-2">Combo Gà Rán &amp; Pepsi</h3>
<p class="text-on-surface-variant mb-6 line-clamp-2">2 miếng gà giòn cay, 1 khoai tây chiên size M và 1 ly Pepsi mát lạnh.</p>
<div class="flex items-center justify-between">
<div>
<span class="block text-on-surface-variant line-through text-sm">120.000đ</span>
<span class="text-primary-fixed font-headline font-extrabold text-2xl">89.000đ</span>
</div>
<button class="kinetic-gradient text-white font-headline font-bold px-6 py-3 rounded-lg active:scale-90 transition-transform">Đặt ngay</button>
</div>
</div>
</div>
<!-- Combo Card 2 -->
<div class="group bg-surface-container-lowest rounded-xl overflow-hidden hover:scale-[1.03] transition-all duration-300 hover:shadow-[0_40px_40px_-20px_rgba(45,47,47,0.06)]">
<div class="aspect-square overflow-hidden relative">
<img alt="Combo Burger Đôi" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" data-alt="Two gourmet double beef burgers with melting cheese and fresh lettuce stacked neatly against a solid orange background" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDrDDt8js2WFNLo8YzPMBSf4RgKqsfITPKcMpSxoHjoAd_1UhXWFR8dPwdPUxsUDsL2FaOcjVDsD1NBHuw7lG5G4k-U-u14rcVhTIyP-HeysMUBAEV7M98c0joi8JLqbICrAbTLNOJVzFz2ro7isjCOGL5ESDhzwu6O458a8r4GeufRXanCztjPKYlFtJT0J_eL3mEPYVQQoZnKaNgPg7QBLoWG4RMspHyYM9VEpndtDEIWvZcteIBhdqmPAeJDLCtfVq-pVwoDZgY"/>
<div class="absolute top-4 right-4 bg-tertiary-container text-on-tertiary-container font-headline font-extrabold px-3 py-1 rounded-lg text-xs">BEST VALUE</div>
</div>
<div class="p-8">
<h3 class="font-headline font-bold text-2xl mb-2">Combo Burger Đôi</h3>
<p class="text-on-surface-variant mb-6 line-clamp-2">2 Burger bò phô mai, 2 phần khoai và 2 trà đào sả tắc thơm lừng.</p>
<div class="flex items-center justify-between">
<div>
<span class="block text-on-surface-variant line-through text-sm">250.000đ</span>
<span class="text-primary-fixed font-headline font-extrabold text-2xl">149.000đ</span>
</div>
<button class="kinetic-gradient text-white font-headline font-bold px-6 py-3 rounded-lg active:scale-90 transition-transform">Đặt ngay</button>
</div>
</div>
</div>
<!-- Combo Card 3 -->
<div class="group bg-surface-container-lowest rounded-xl overflow-hidden hover:scale-[1.03] transition-all duration-300 hover:shadow-[0_40px_40px_-20px_rgba(45,47,47,0.06)]">
<div class="aspect-square overflow-hidden relative">
<img alt="Combo Gia Đình" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" data-alt="A large pizza party box featuring one large pepperoni pizza, 6 chicken wings, and a 1.5L soda bottle on a wooden table" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCFT9R1pF0nWAazuX8TUxMpMuCGjweOlcdnf9tJpBg47qTuSfENNJL7MNdUV7bAV4JagTrQtLCp9myk1ct9mNo1SjopWRDRVGb2rvDyrsCKDAexUAhAcZO9Tg_OMwuJd3lZNyWWhUnmsWGFdwz4DpV_ITVOZRJP0ljMWbzFRfYrwC4wNtYAEqX5xzliFlXxL6OSX2pOqz-C5sGM7GPh0Km4qdA94_Dc8jzbqCtrmHuP9RqjdcHy1gGG2tgmmv1QshpSiNPz79mqjfY"/>
</div>
<div class="p-8">
<h3 class="font-headline font-bold text-2xl mb-2">Combo Gia Đình</h3>
<p class="text-on-surface-variant mb-6 line-clamp-2">1 Pizza size L, 6 cánh gà chiên mắm, salad Nga và Pepsi 1.5L.</p>
<div class="flex items-center justify-between">
<div>
<span class="block text-on-surface-variant line-through text-sm">450.000đ</span>
<span class="text-primary-fixed font-headline font-extrabold text-2xl">299.000đ</span>
</div>
<button class="kinetic-gradient text-white font-headline font-bold px-6 py-3 rounded-lg active:scale-90 transition-transform">Đặt ngay</button>
</div>
</div>
</div>
</div>
</section>
<!-- Section 2: Ưu Đãi Đặc Biệt -->
<section class="bg-surface-container-low py-20 overflow-hidden">
<div class="max-w-7xl mx-auto px-6">
<div class="flex flex-col md:flex-row items-center gap-12">
<div class="flex-1 space-y-6">
<h2 class="font-headline font-extrabold text-5xl leading-tight">Ưu Đãi Đặc Biệt <br/> <span class="text-error">Chỉ Trong 2 Giờ!</span></h2>
<p class="text-on-surface-variant text-xl max-w-lg">Flash Deal đặc biệt dành riêng cho khách hàng đặt app. Giảm thêm 20% khi nhập mã LINHFRESH.</p>
<div class="flex gap-4">
<div class="bg-surface-container-lowest p-4 rounded-xl text-center min-w-[80px]">
<span class="block font-headline font-extrabold text-3xl">01</span>
<span class="text-xs uppercase font-bold text-outline">Giờ</span>
</div>
<div class="bg-surface-container-lowest p-4 rounded-xl text-center min-w-[80px]">
<span class="block font-headline font-extrabold text-3xl">42</span>
<span class="text-xs uppercase font-bold text-outline">Phút</span>
</div>
<div class="bg-surface-container-lowest p-4 rounded-xl text-center min-w-[80px]">
<span class="block font-headline font-extrabold text-3xl">18</span>
<span class="text-xs uppercase font-bold text-outline">Giây</span>
</div>
</div>
</div>
<div class="flex-1 relative">
<div class="absolute -inset-4 kinetic-gradient opacity-10 blur-3xl rounded-full"></div>
<div class="relative bg-surface-container-lowest rounded-3xl p-8 flex gap-6 items-center shadow-xl">
<img alt="Flash Deal" class="w-32 h-32 rounded-2xl object-cover" data-alt="A juicy double-decker cheeseburger with melted cheddar dripping down the sides in a high-contrast studio food shot" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAA8iT-zQFjJuxlGOBzWmz9Me4NZmvFsiClXVh0P-NWx8WgW1R4QaB-ilC3sSRMwmOHsd_2rM6k4UTt9NNnsUKaXBUC7rGplUTA7jZqWJG5Dt-NpByng0MNpy22hSNwW4zZLS9H1FgjfPuuEB9pcFFhBN0IKSOKmP_qNs6Y6K2-lbjXCoIbDT3N0AmYvv_8rMT1sF9QdVYYj2GFwM0fb_jCbvL7WMMjkapPhEskC87iss4KRo-YKYLXmnA99Z8ALM0VsQEFrXpG8x0"/>
<div class="flex-1">
<h4 class="font-headline font-bold text-xl mb-1">Double Cheese Flash</h4>
<p class="text-on-surface-variant text-sm mb-4">Mua 1 tặng 1 duy nhất hôm nay</p>
<button class="bg-primary text-white font-headline font-bold px-6 py-2 rounded-lg text-sm w-full">Lấy ưu đãi ngay</button>
</div>
</div>
</div>
</div>
</div>
</section>
<!-- Section 3: Gợi Ý Hôm Nay -->
<section class="max-w-7xl mx-auto px-6 py-20">
<h2 class="font-headline font-extrabold text-3xl mb-12">Gợi Ý Hôm Nay</h2>
<div class="grid grid-cols-2 md:grid-cols-4 gap-6">
<!-- Suggestion Item 1 -->
<div class="group cursor-pointer">
<div class="aspect-square rounded-2xl overflow-hidden mb-4 bg-white relative shadow-sm">
<img alt="Khoai tây chiên" class="w-full h-full object-cover group-hover:scale-105 transition-transform" data-alt="A bucket of golden thin-cut french fries seasoned with herbs on a minimalist white background" src="https://lh3.googleusercontent.com/aida-public/AB6AXuABXfBO8QYsTyWm-kaHrGCQd9RTWOH_pq2ByRpe61blEKAUozITRLuh3b1T0oVG5luYrcERWf22I_FbG7HWO4OkqQXUEGwal1eVPCLfBDmX1IZYfHRJu4OmgxArbYg99zcjcrgLXzyEGHUvwn3dkkU4X_1gLAIxpgFbqnlBFfHeKatdVRCXz3QEnyR66kk6BP0GkMpNiaQi_1MKFFo3_i3ZQ5DoNWSCPiwCkF3Cs8YPlOynQ9y--8hwkfdVghGqZsUnbeVk8qNtkeI"/>
<button class="absolute bottom-3 right-3 bg-white w-10 h-10 rounded-full flex items-center justify-center shadow-lg text-primary hover:bg-primary hover:text-white transition-colors">
<span class="material-symbols-outlined">add</span>
</button>
</div>
<h4 class="font-headline font-bold">Khoai tây lắc phô mai</h4>
<p class="text-primary-fixed font-bold">35.000đ</p>
</div>
<!-- Suggestion Item 2 -->
<div class="group cursor-pointer">
<div class="aspect-square rounded-2xl overflow-hidden mb-4 bg-white relative shadow-sm">
<img alt="Trà đào" class="w-full h-full object-cover group-hover:scale-105 transition-transform" data-alt="A refreshing glass of peach iced tea with fresh peach slices and mint leaves against a soft sunlit background" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBp_KwW84rP7nXHj7siraygwpLz1v8MfYb-4eBQtvWr3ETyp6lU5RndGsKLmG0wZYHGCGC4ooMk4tm7Pz0rqw9G-hLRjXn7tuQwoIQisSj_i4gsz7YdF9CcG6ebM0wMcK7oHLCbH6Tq94WGLhNOqm63TgnAMtviJhn7UwXad2mZWkgwy202aNBRsAXN18FXNJqbm_IFtFecZvnaNbmxm-5gGWt4cDpf--YwXnjduYegPis376dA3TYiDyXr0cgDiYMTdXVjCDOsNs8"/>
<button class="absolute bottom-3 right-3 bg-white w-10 h-10 rounded-full flex items-center justify-center shadow-lg text-primary hover:bg-primary hover:text-white transition-colors">
<span class="material-symbols-outlined">add</span>
</button>
</div>
<h4 class="font-headline font-bold">Trà đào sả tắc</h4>
<p class="text-primary-fixed font-bold">29.000đ</p>
</div>
<!-- Suggestion Item 3 -->
<div class="group cursor-pointer">
<div class="aspect-square rounded-2xl overflow-hidden mb-4 bg-white relative shadow-sm">
<img alt="Cánh gà" class="w-full h-full object-cover group-hover:scale-105 transition-transform" data-alt="Two spicy glazed chicken wings on a small white plate with a side of ranch dressing" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA0gIjlsPAZE6ZAYn55upDnD6roZglEQe9DAaQECw90Ba1AqQFww0jpy3u9l-vQ-XagbAnUY14gV95_A1dyrYQIphwV94Fm29J4SXWaF1v4aTzLuCbqvLO4ILbYjspHmy5k-mUjhEOCKdq1UbV8dAwDdKP0WhVzR90vUvBzXOjijKzCpjj0jtUcpbx2gu4rJJK1m3rOztmM7DC2UmSjh3e6gLrvsMfYv34pWrtV4JCbGwClB6gGjskVU4zkRAwZKBZWVZBde8mxYQI"/>
<button class="absolute bottom-3 right-3 bg-white w-10 h-10 rounded-full flex items-center justify-center shadow-lg text-primary hover:bg-primary hover:text-white transition-colors">
<span class="material-symbols-outlined">add</span>
</button>
</div>
<h4 class="font-headline font-bold">Cánh gà sốt cay (2pcs)</h4>
<p class="text-primary-fixed font-bold">45.000đ</p>
</div>
<!-- Suggestion Item 4 -->
<div class="group cursor-pointer">
<div class="aspect-square rounded-2xl overflow-hidden mb-4 bg-white relative shadow-sm">
<img alt="Salad" class="w-full h-full object-cover group-hover:scale-105 transition-transform" data-alt="A fresh garden salad bowl with cherry tomatoes, cucumbers, and balsamic glaze drizzle" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBYiD85MxxvgT_GUuTvRImoVI9nkss1aDbsQSr1XifzIPcTuJnz0gdTElNkARV3M-vHLoMSOT_aBUgtC5qeilKtXasn0di3-sWuy9IJVF3wrR_wmdKICHBLmm7c-Ov3n4UkLY41Q3KOp57uaoNYwB-OQgFfLLMscJEEv6eEvjzmdFQHed2XQiPXxd9gY7Bm38BMF_MFD6dAJAXutHz_QU0-Tdbf9b3VsKCMgUtQkLQ-fEeK7IjOM2G8qlym2ELhhky2L53HNtSV_hA"/>
<button class="absolute bottom-3 right-3 bg-white w-10 h-10 rounded-full flex items-center justify-center shadow-lg text-primary hover:bg-primary hover:text-white transition-colors">
<span class="material-symbols-outlined">add</span>
</button>
</div>
<h4 class="font-headline font-bold">Salad vườn rau củ</h4>
<p class="text-primary-fixed font-bold">39.000đ</p>
</div>
</div>
</section>
</main>
<!-- Footer -->
<footer class="bg-zinc-100 dark:bg-zinc-900 w-full py-12 mt-auto">
<div class="flex flex-col md:flex-row justify-between items-center px-8 max-w-7xl mx-auto gap-8">
<div class="flex flex-col gap-4 items-center md:items-start">
<div class="text-xl font-bold text-zinc-900 dark:text-white font-headline">Linhfood</div>
<p class="font-['Inter'] text-sm text-zinc-500 max-w-xs text-center md:text-left">
                    © 2024 Linhfood Kinetic Gourmet. All rights reserved.
                </p>
</div>
<div class="flex flex-wrap justify-center gap-6 font-['Inter'] text-sm">
