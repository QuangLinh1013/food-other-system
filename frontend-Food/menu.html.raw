<!-- Category: Combo -->
<section class="scroll-mt-28" id="combo">
<div class="flex items-end justify-between mb-8">
<div>
<h2 class="text-3xl font-black font-headline text-on-background tracking-tight">Combo Siêu Tiết Kiệm</h2>
<div class="h-1.5 w-12 bg-primary-container mt-2 rounded-full"></div>
