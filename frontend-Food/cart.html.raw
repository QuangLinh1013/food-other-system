<!DOCTYPE html>

<html lang="vi"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "secondary": "#3b5f78",
                    "on-secondary-fixed-variant": "#375c75",
                    "error-dim": "#b92902",
                    "secondary-fixed": "#bce1ff",
                    "on-surface-variant": "#5a5c5c",
                    "outline": "#757777",
                    "on-secondary": "#e9f4ff",
                    "secondary-fixed-dim": "#aed3f1",
                    "on-surface": "#2d2f2f",
                    "tertiary-fixed": "#fccc33",
                    "on-tertiary-container": "#594500",
                    "surface-container-high": "#e1e3e3",
                    "inverse-primary": "#fd8603",
                    "on-background": "#2d2f2f",
                    "tertiary-dim": "#634d00",
                    "on-primary-fixed": "#0f0400",
                    "surface-container-lowest": "#ffffff",
                    "on-secondary-fixed": "#183f57",
                    "primary-fixed": "#fd8603",
                    "on-secondary-container": "#2d526b",
                    "on-primary-fixed-variant": "#4f2600",
                    "surface-dim": "#d2d5d5",
                    "error-container": "#f95630",
                    "surface-container-highest": "#dbdddd",
                    "surface": "#f6f6f6",
                    "surface-tint": "#8e4900",
                    "surface-container": "#e7e8e8",
                    "error": "#b02500",
                    "primary-dim": "#7d3f00",
                    "tertiary-container": "#fccc33",
                    "on-tertiary-fixed": "#423200",
                    "on-tertiary-fixed-variant": "#644e00",
                    "surface-variant": "#dbdddd",
                    "primary-fixed-dim": "#e97b00",
                    "on-error": "#ffefec",
                    "tertiary": "#715800",
                    "on-tertiary": "#fff1d6",
                    "tertiary-fixed-dim": "#edbe23",
                    "background": "#f6f6f6",
                    "surface-bright": "#f6f6f6",
                    "on-error-container": "#520c00",
                    "surface-container-low": "#f0f1f1",
                    "primary-container": "#fd8603",
                    "outline-variant": "#acadad",
                    "inverse-on-surface": "#9c9d9d",
                    "primary": "#8e4900",
                    "on-primary-container": "#421e00",
                    "secondary-dim": "#2e536c",
                    "inverse-surface": "#0c0f0f",
                    "on-primary": "#fff0e7",
                    "secondary-container": "#bce1ff"
            },
            "borderRadius": {
                    "DEFAULT": "0.25rem",
                    "lg": "1rem",
                    "xl": "1.25rem",
                    "full": "9999px"
            },
            "fontFamily": {
                    "headline": ["Plus Jakarta Sans"],
                    "body": ["Inter"],
                    "label": ["Inter"]
            }
          },
        },
      }
    </script>
<style>
      body { font-family: 'Inter', sans-serif; background-color: #f6f6f6; }
      h1, h2, h3, .brand-font { font-family: 'Plus Jakarta Sans', sans-serif; }
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
      .primary-gradient {
        background: linear-gradient(135deg, #8e4900 0%, #fd8603 100%);
      }
    </style>
</head>
<body class="text-on-surface">
<!-- TopAppBar -->
<header class="bg-white/80 dark:bg-zinc-900/80 backdrop-blur-md fixed top-0 w-full z-50 tonal-transition">
<div class="flex justify-between items-center px-6 py-4 max-w-7xl mx-auto">
<div class="text-2xl font-extrabold tracking-tighter text-orange-600 dark:text-orange-500 brand-font">Linhfood</div>
<nav class="hidden md:flex items-center gap-8">
<a class="text-zinc-500 dark:text-zinc-400 hover:text-orange-500 transition-colors font-medium" href="#">Thực đơn</a>
<a class="text-orange-600 font-bold hover:text-orange-500 transition-colors" href="#">Giỏ hàng</a>
</nav>
<div class="flex items-center gap-4">
<button class="material-symbols-outlined text-zinc-500 hover:text-orange-500 transition-transform scale-95 active:scale-90" data-icon="shopping_cart">shopping_cart</button>
</div>
</div>
</header>
<main class="pt-24 pb-12 px-6 max-w-7xl mx-auto">
<div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
<!-- Left Column: Cart Items -->
<div class="lg:col-span-8">
<h1 class="text-4xl font-extrabold mb-8 tracking-tight">Giỏ hàng của bạn</h1>
<div class="space-y-6">
<!-- Cart Item 1 -->
<div class="bg-surface-container-lowest p-6 rounded-xl flex flex-col sm:flex-row gap-6 items-center sm:items-start group hover:shadow-[0_40px_40px_-20px_rgba(45,47,47,0.06)] transition-all duration-300">
<div class="relative w-32 h-32 flex-shrink-0 bg-surface-container rounded-lg overflow-hidden">
<img alt="Burger Bo" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" data-alt="Gourmet double cheeseburger with melting cheddar, fresh lettuce, and tomato on a toasted brioche bun with professional food styling" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBA8gY2pC6j4GTepCRhIS19V91aNUPJz1VEsjQjiwG6muJ-XX9F67SxdbVHNaxMe3P6FCoWtoq8bS470UNqCcGL7Y9nrh7IADbj0bKya4wtO7VE5US0pe6sGjvMCudLKjudBMZFB-Bb8n62ZtvDFrfhsPEbZCg7jthDV7Sz_BbN9IxPaUzTxMlWOiNVUGekO0gx9cK9QbbfR13MW0SVg-W5x6VVk4gN0nc_-Ta_n5n7KPV2u0AtEgazNDdgDVcy4yf9b0yBWu4y518"/>
</div>
<div class="flex-grow text-center sm:text-left">
<h3 class="text-xl font-bold mb-1">Burger Bò Phô Mai Đặc Biệt</h3>
<p class="text-on-surface-variant text-sm mb-4">Size L lớn, thêm thịt xông khói áp chảo giòn tan</p>
<div class="flex flex-wrap items-center justify-center sm:justify-start gap-6">
<div class="flex items-center bg-surface-container-low rounded-full px-3 py-1">
<button class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-surface-container-high transition-colors font-bold text-lg">-</button>
<span class="w-10 text-center font-semibold">1</span>
<button class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-surface-container-high transition-colors font-bold text-lg">+</button>
</div>
<button class="text-error-dim font-medium text-sm hover:underline">Xóa</button>
</div>
</div>
<div class="text-right sm:self-center">
<span class="text-2xl font-black text-on-surface">145.000₫</span>
</div>
</div>
<!-- Cart Item 2 -->
<div class="bg-surface-container-lowest p-6 rounded-xl flex flex-col sm:flex-row gap-6 items-center sm:items-start group hover:shadow-[0_40px_40px_-20px_rgba(45,47,47,0.06)] transition-all duration-300">
<div class="relative w-32 h-32 flex-shrink-0 bg-surface-container rounded-lg overflow-hidden">
<img alt="Pizza Hai San" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" data-alt="Stone-baked seafood pizza with prawns, squid, and mussels on a bed of rich tomato sauce and bubbling mozzarella cheese" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBW4HRQ7O-jMEZM_Y2XfJ4ycdzYrsNQINvakgVBupDGLuoavv2JWMJTeIWQCWslIOeCdREmj-YX0qBmWrb5o3_W_mKAgGHHkvFuQA5vSkDDV0Lbs9hnafxZx2tUy-ULXpfqak932UB2_5A8_zs6QwH-EcDU2p9UWUSTzd08B0hL7ZrP_s560ORALiADY_2SZyoun3zmS_1067E91EJWLpT_R0MalB9nk6ReoA4FI204FEz5Q5rrJSTJGds5a_sqQH8l9pp7c9phKvA"/>
</div>
<div class="flex-grow text-center sm:text-left">
<h3 class="text-xl font-bold mb-1">Pizza Hải Sản Sốt Pesto</h3>
<p class="text-on-surface-variant text-sm mb-4">Đế mỏng giòn, hải sản tươi trong ngày</p>
<div class="flex flex-wrap items-center justify-center sm:justify-start gap-6">
<div class="flex items-center bg-surface-container-low rounded-full px-3 py-1">
<button class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-surface-container-high transition-colors font-bold text-lg">-</button>
<span class="w-10 text-center font-semibold">1</span>
<button class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-surface-container-high transition-colors font-bold text-lg">+</button>
</div>
<button class="text-error-dim font-medium text-sm hover:underline">Xóa</button>
</div>
</div>
<div class="text-right sm:self-center">
<span class="text-2xl font-black text-on-surface">220.000₫</span>
</div>
</div>
</div>
</div>
<!-- Right Column: Order Summary -->
<div class="lg:col-span-4">
<div class="sticky top-24 space-y-6">
<div class="bg-surface-container-lowest p-8 rounded-xl shadow-sm">
<h2 class="text-2xl font-extrabold mb-6 tracking-tight">Tóm tắt đơn hàng</h2>
<!-- Promo Code -->
<div class="mb-8">
<div class="flex gap-2">
<input class="flex-grow bg-surface-container-low border-none rounded-lg px-4 py-3 focus:ring-2 focus:ring-primary text-sm font-medium" placeholder="Mã giảm giá" type="text"/>
<button class="bg-secondary text-on-secondary px-6 py-3 rounded-lg font-bold text-sm hover:bg-secondary-dim transition-colors">Áp dụng</button>
</div>
</div>
<!-- Price Breakdown -->
<div class="space-y-4 mb-8">
<div class="flex justify-between items-center text-on-surface-variant">
<span class="font-medium">Tạm tính</span>
<span class="font-bold">365.000₫</span>
</div>
<div class="flex justify-between items-center text-on-surface-variant">
<span class="font-medium">Phí vận chuyển</span>
<span class="font-bold">15.000₫</span>
</div>
<div class="pt-4 border-t border-dashed border-outline-variant/30 flex justify-between items-end">
<span class="text-lg font-bold">Tổng cộng</span>
<div class="text-right">
<div class="text-4xl font-black text-primary leading-none">380.000₫</div>
<p class="text-[10px] text-on-surface-variant mt-1">Đã bao gồm VAT</p>
</div>
</div>
</div>
<!-- CTA -->
<button class="w-full primary-gradient text-on-primary py-5 rounded-lg font-extrabold text-xl tracking-tight hover:opacity-90 active:scale-[0.98] transition-all shadow-xl shadow-orange-600/20">
                            Thanh toán giao hàng
                        </button>
<!-- Trust Badges -->
<div class="mt-8 grid grid-cols-2 gap-4">
<div class="flex flex-col items-center text-center p-3 rounded-lg bg-surface-container-low">
<span class="material-symbols-outlined text-primary mb-1" style="font-variation-settings: 'FILL' 1;">verified_user</span>
<span class="text-[10px] font-bold uppercase tracking-wider text-on-surface">Bảo mật thanh toán</span>
</div>
<div class="flex flex-col items-center text-center p-3 rounded-lg bg-surface-container-low">
<span class="material-symbols-outlined text-primary mb-1" style="font-variation-settings: 'FILL' 1;">currency_exchange</span>
<span class="text-[10px] font-bold uppercase tracking-wider text-on-surface">Hoàn tiền nhanh chóng</span>
</div>
</div>
</div>
<!-- Additional Context/Promotion -->
<div class="bg-tertiary-container/20 p-6 rounded-xl border border-tertiary-container/30">
<div class="flex gap-4">
<span class="material-symbols-outlined text-tertiary" style="font-variation-settings: 'FILL' 1;">stars</span>
<div>
<p class="text-sm font-bold text-on-tertiary-container">Bạn tích lũy được 38 điểm!</p>
<p class="text-xs text-on-tertiary-container/80 mt-1">Dùng điểm này để đổi các món quà bất ngờ cho lần đặt sau.</p>
</div>
</div>
</div>
</div>
</div>
</div>
</main>
<!-- Footer -->
<footer class="bg-zinc-100 dark:bg-zinc-950 w-full py-12 mt-auto">
<div class="flex flex-col md:flex-row justify-between items-center px-8 w-full max-w-7xl mx-auto gap-8">
<div class="flex flex-col gap-2">
<span class="font-['Plus_Jakarta_Sans'] font-black text-lg text-orange-600">Linhfood</span>
<p class="text-zinc-500 font-['Inter'] text-sm">© 2024 Linhfood Kinetic Gourmet</p>
</div>
<div class="flex gap-8">
<a class="text-zinc-500 hover:text-zinc-900 transition-opacity opacity-80 hover:opacity-100 text-sm font-medium" href="#">Privacy</a>
<a class="text-zinc-500 hover:text-zinc-900 transition-opacity opacity-80 hover:opacity-100 text-sm font-medium" href="#">Terms</a>
<a class="text-zinc-500 hover:text-zinc-900 transition-opacity opacity-80 hover:opacity-100 text-sm font-medium" href="#">Support</a>
<a class="text-zinc-500 hover:text-zinc-900 transition-opacity opacity-80 hover:opacity-100 text-sm font-medium" href="#">Contact</a>
</div>
</div>
</footer>
</body></html>